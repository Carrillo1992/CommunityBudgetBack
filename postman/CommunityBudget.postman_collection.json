{
	"info": {
		"_postman_id": "cb-api-collection",
		"name": "CommunityBudget API",
		"description": "Colección de endpoints para la API de CommunityBudget",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080/api/v1",
			"type": "string"
		},
		{
			"key": "accessToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "refreshToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "userId",
			"value": "1",
			"type": "string"
		},
		{
			"key": "passwordResetEmail",
			"value": "test@example.com",
			"type": "string"
		},
		{
			"key": "passwordResetToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "newPassword",
			"value": "NewPassword456!",
			"type": "string"
		},
		{
			"key": "googleIdToken",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"description": "Operaciones de autenticación",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Test User\",\n    \"email\": \"test@example.com\",\n    \"password\": \"Password123!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						},
						"description": "Registra un nuevo usuario en el sistema"
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.accessToken) {",
									"    pm.collectionVariables.set(\"accessToken\", jsonData.accessToken);",
									"}",
									"if (jsonData.refreshToken) {",
									"    pm.collectionVariables.set(\"refreshToken\", jsonData.refreshToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"Password123!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						},
						"description": "Autentica al usuario y devuelve un token JWT. Los tokens se guardan automáticamente en las variables de la colección."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.accessToken) {",
									"    pm.collectionVariables.set(\"accessToken\", jsonData.accessToken);",
									"}",
									"if (jsonData.refreshToken) {",
									"    pm.collectionVariables.set(\"refreshToken\", jsonData.refreshToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/refresh",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "refresh"]
						},
						"description": "Obtiene un nuevo token JWT usando el refresh token. Los nuevos tokens se guardan automáticamente."
					},
					"response": []
				},
				{
					"name": "Forgot Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/auth/forgot-password?email={{passwordResetEmail}}",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "forgot-password"],
							"query": [
								{
									"key": "email",
									"value": "{{passwordResetEmail}}"
								}
							]
						},
						"description": "Solicita el envío de correo de recuperación para el email indicado."
					},
					"response": []
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"token\": \"{{passwordResetToken}}\",\n    \"password\": \"{{newPassword}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/auth/reset-password",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "reset-password"]
						},
						"description": "Restablece la contraseña usando el token recibido por correo."
					},
					"response": []
				},
				{
					"name": "Google Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.accessToken) {",
									"    pm.collectionVariables.set(\"accessToken\", jsonData.accessToken);",
									"}",
									"if (jsonData.refreshToken) {",
									"    pm.collectionVariables.set(\"refreshToken\", jsonData.refreshToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"idToken\": \"{{googleIdToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/oauth/google",
							"host": ["{{baseUrl}}"],
							"path": ["oauth", "google"]
						},
						"description": "Autentica al usuario usando un token de ID de Google (idToken). Los tokens generados se guardan automáticamente en las variables de la colección."
					},
					"response": []
				}
			]
		},
		{
			"name": "User",
			"description": "Operaciones relacionadas con usuarios",
			"item": [
				{
					"name": "Get Current User",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/user/me",
							"host": ["{{baseUrl}}"],
							"path": ["user", "me"]
						},
						"description": "Obtiene la información del usuario actualmente autenticado"
					},
					"response": []
				},
				{
					"name": "Update Current User",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Name\",\n    \"email\": \"updated@example.com\",\n    \"avatarUrl\": \"https://example.com/avatar.png\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/user/me",
							"host": ["{{baseUrl}}"],
							"path": ["user", "me"]
						},
						"description": "Actualiza la información del usuario autenticado"
					},
					"response": []
				},
				{
					"name": "Change Password",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"currentPassword\": \"Password123!\",\n    \"newPassword\": \"NewPassword456!\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/user/me/change-password",
							"host": ["{{baseUrl}}"],
							"path": ["user", "me", "change-password"]
						},
						"description": "Permite al usuario autenticado cambiar su contraseña"
					},
					"response": []
				},
				{
					"name": "Delete Current User",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/user/me",
							"host": ["{{baseUrl}}"],
							"path": ["user", "me"]
						},
						"description": "Elimina la cuenta del usuario autenticado"
					},
					"response": []
				}
			]
		},
		{
			"name": "Admin",
			"description": "Operaciones de administración (requiere rol ADMIN)",
			"item": [
				{
					"name": "Get All Users",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/user",
							"host": ["{{baseUrl}}"],
							"path": ["user"]
						},
						"description": "Obtiene la lista de todos los usuarios del sistema. Requiere rol ADMIN."
					},
					"response": []
				},
				{
					"name": "Get User By ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/user/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["user", "{{userId}}"]
						},
						"description": "Obtiene la información de un usuario específico por su ID. Requiere rol ADMIN."
					},
					"response": []
				},
				{
					"name": "Update User By ID",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Admin Updated Name\",\n    \"email\": \"admin.updated@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/user/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["user", "{{userId}}"]
						},
						"description": "Actualiza la información de un usuario específico por su ID. Requiere rol ADMIN."
					},
					"response": []
				},
				{
					"name": "Delete User By ID",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/user/{{userId}}",
							"host": ["{{baseUrl}}"],
							"path": ["user", "{{userId}}"]
						},
						"description": "Elimina un usuario específico por su ID. Requiere rol ADMIN."
					},
					"response": []
				},
				{
					"name": "Promote User to Admin",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/user/{{userId}}/promote-admin",
							"host": ["{{baseUrl}}"],
							"path": ["user", "{{userId}}", "promote-admin"]
						},
						"description": "Asigna el rol ADMIN a un usuario específico. Requiere rol ADMIN."
					},
					"response": []
				},
				{
					"name": "Revoke Admin Role",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{accessToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/user/{{userId}}/revoke-admin",
							"host": ["{{baseUrl}}"],
							"path": ["user", "{{userId}}", "revoke-admin"]
						},
						"description": "Revoca el rol ADMIN de un usuario específico. El usuario mantendrá el rol USER. Requiere rol ADMIN."
					},
					"response": []
				}
			]
		}
	]
}

